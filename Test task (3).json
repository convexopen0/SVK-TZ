    {
      "parameters": {
        "jsCode": "// Режим: Run Once for All Items\nconst rows = $input.all().map(item => item.json);\n\n// В цій гілці upstream context — тільки один датасет,\n// тому .first() тут безпечний: у гілку прилетіла одна конкретна\n// Code in JavaScript execution, все від неї.\nconst meta = $('Code in JavaScript').item.json;\nconst jobData = $('Execute a SQL query1').item.json;\n\nreturn [{\n  json: {\n    dataset_id: meta.dataset_id,\n    job_id:     jobData.job_id,\n    data:       rows,\n    row_count:  rows.length,\n    fetched_at: new Date().toISOString()\n  }\n}];"
      },
