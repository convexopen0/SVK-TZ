    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// Цей код виконається окремо для кожного датасета з попередньої ноди.\n// $input.item.json — дані поточного item.\n\nconst item = $input.item.json;\n\n// Вирішуємо: створюємо новий job чи продовжуємо існуючий ретрай?\n// Якщо з функції прийшов pending_job_id — це ретрай, ми оновлюємо існуючий.\n// Якщо null — створюємо новий job з attempt=1.\n\nconst isRetry = item.pending_job_id !== null;\n\nreturn {\n  json: {\n    dataset_id:     item.dataset_id,\n    name:           item.name,\n    source_type:    item.source_type,\n    source_config:  item.source_config,\n    max_retries:    item.max_retries,\n    reason:         item.reason,\n    // Поля для job-а:\n    job_id:         item.pending_job_id,          // null для нового\n    attempt:        isRetry ? item.pending_attempt + 1 : 1,\n    is_retry:       isRetry\n  }\n};"
      },
