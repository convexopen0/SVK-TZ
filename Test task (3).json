    {
      "parameters": {
        "jsCode": "// Режим: Run Once for Each Item\nconst item = $input.item.json;\n\n// Весь контекст датасета живе в Code1 — звідти і беремо\nconst ctx = $('Code in JavaScript').item.json;\n\nconst attempt = ctx.attempt;\nconst maxRetries = ctx.max_retries;\n\n// Експоненційний backoff: 30, 60, 120, 240, 480 секунд\nconst backoffSec = 30 * Math.pow(2, attempt - 1);\nconst nextRetryAt = new Date(Date.now() + backoffSec * 1000).toISOString();\n\nconst shouldRetry = attempt < maxRetries;\n\n// Текст помилки з error output\nconst errorMessage = \n  $input.item.error?.message || \n  item.error?.message || \n  item.message || \n  JSON.stringify(item).slice(0, 500);\n\nreturn {\n  json: {\n    job_id:        ctx.job_id,\n    dataset_id:    ctx.dataset_id,\n    dataset_name:  ctx.name,\n    attempt:       attempt,\n    max_retries:   maxRetries,\n    should_retry:  shouldRetry,\n    next_retry_at: nextRetryAt,\n    error_message: errorMessage,\n    new_status:    shouldRetry ? 'retrying' : 'failed'\n  }\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        416,
        176
      ],
      "id": "d67d7dd0-1d74-4068-9ff3-f122744965cb",
      "name": "Code in JavaScript2"
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "update refresh_jobs\nset status = $1,\n    finished_at = case when $1 = 'failed' then now() else finished_at end,\n    next_retry_at = case when $1 = 'retrying' then $2::timestamptz else null end,\n    error_message = $3\nwhere id = $4;",
        "options": {
          "queryReplacement": "={{ $json.new_status }}, {{ $json.next_retry_at }}, {{ $json.error_message }}, {{ $json.job_id }}"
        }
      },
