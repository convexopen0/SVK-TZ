        "query": "with deactivate as (\n  update snapshots\n  set is_current = false\n  where dataset_id = $1::uuid and is_current = true\n  returning 1\n)\ninsert into snapshots (dataset_id, data, row_count, is_current)\nvalues ($1::uuid, $2::jsonb, $3::int, true)\nreturning id;",
        "options": {
          "queryReplacement": "={{ $json.dataset_id }}, {{ JSON.stringify($json.data) }}, {{ $json.row_count }}"
        }
